# ProtoAGI local endpoint
PROTOAGI_BASE_URL=http://127.0.0.1:8080/v1
PROTOAGI_MODEL=gpt-oss-20b-MXFP4
PROTOAGI_DB=data/protoagi.sqlite3
PROTOAGI_TEMPERATURE=0.6
PROTOAGI_TOP_P=1.0
# Sized for a reasoning model: the deepseek reasoning channel and the
# visible reply share this token budget. 4096 leaves headroom for a
# medium chain of thought plus a Telegram-length answer.
PROTOAGI_MAX_TOKENS=4096
# Telegram decision JSON (smart-mode group filter, sticker pick, tool_request).
PROTOAGI_DECISION_MAX_TOKENS=2560
# Free-form reply composer when the decision arm did not embed a reply.
PROTOAGI_REPLY_MAX_TOKENS=2048
# run-nikola.bat exports this from -CtxSize. Keep it here for manual
# python -m protoagi telegram runs so prompt compaction has the same target.
PROTOAGI_CONTEXT_SIZE=8192
# Upper bound for the Telegram user JSON payload sent beside the system prompt.
# The bot compacts recent history/media metadata before a request can exceed 8k.
PROTOAGI_TELEGRAM_CONTEXT_MAX_CHARS=6500

# Optional model call per memory write for better importance/kind scoring.
# Disabled by default; heuristic scoring remains deterministic and zero-latency.
PROTOAGI_LLM_IMPORTANCE=0
PROTOAGI_PLAN_REFLECT=1
PROTOAGI_PLAN_CALL_LIMIT=2

# Optional embedding endpoint for semantic recall.
# When PROTOAGI_EMBED_MODEL is set and PROTOAGI_EMBED_BASE_URL points at
# localhost, run-nikola.bat / start-nikola-stack.ps1 will start a separate
# embedding llama-server on the matching port using PROTOAGI_EMBED_HF_REPO
# (or its default). Leave PROTOAGI_EMBED_MODEL empty to disable semantic
# recall; the bot falls back to FTS-only memory.
PROTOAGI_EMBED_BASE_URL=http://127.0.0.1:8082/v1
PROTOAGI_EMBED_MODEL=
PROTOAGI_EMBED_HF_REPO=CompendiumLabs/bge-m3-gguf:Q4_K_M
PROTOAGI_EMBED_DIMENSIONS=
PROTOAGI_EMBED_TIMEOUT_SECONDS=30
# flat is exact; lsh is an approximate pure-Python backend for larger stores.
PROTOAGI_EMBED_BACKEND=flat

# Telegram Bot API
# Create a token with @BotFather. Keep the real token only in .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLL_TIMEOUT=25

# Optional OpenAI-compatible vision endpoint for Telegram photos/images.
# Leave PROTOAGI_VISION_MODEL empty to disable image recognition.
PROTOAGI_VISION_BASE_URL=http://127.0.0.1:8081/v1
PROTOAGI_VISION_MODEL=
PROTOAGI_VISION_HF_REPO=ggml-org/SmolVLM2-2.2B-Instruct-GGUF:Q4_K_M
PROTOAGI_VISION_MAX_BYTES=8388608
PROTOAGI_VISION_TIMEOUT_SECONDS=120

# Optional voice transcription / TTS endpoints.
# Voice transcription expects an OpenAI-compatible /audio/transcriptions API.
PROTOAGI_VOICE_BASE_URL=http://127.0.0.1:8083/v1
PROTOAGI_VOICE_MODEL=
PROTOAGI_VOICE_MAX_BYTES=16777216
PROTOAGI_VOICE_TIMEOUT_SECONDS=120
PROTOAGI_STORE_VOICE=1
# TTS is opt-in and sends an additional Telegram voice message for replies.
# Default server is the Ukrainian Piper bridge launched by
# scripts\start-tts-server.ps1 (proper Ukrainian phonetics, runs on CPU,
# no GPU pressure on gpt-oss-20b). It exposes OpenAI-compatible
# /v1/audio/speech and transcodes through ffmpeg to OGG/Opus so Telegram
# sendVoice gets a real voice waveform. Set PROTOAGI_TTS_RESPONSE_FORMAT
# to mp3/aac/flac/wav to route through sendAudio (audio bubble) instead.
PROTOAGI_TTS_ENABLED=0
PROTOAGI_TTS_BASE_URL=http://127.0.0.1:8084/v1
# Model name is informational for the Piper bridge but kept for OpenAI
# API parity. The bridge ignores it and serves whichever Piper voice
# model was downloaded (uk_UA-ukrainian_tts-medium by default).
PROTOAGI_TTS_MODEL=tts-1-hd
# Default voice fallback when the active persona's JSON does not define
# `tts_voice`. Keys are resolved through config/tts/voice_map.json
# (solomiya->lada, mykola->mykyta, plus alloy/echo/fable/onyx/nova/shimmer
# and raw piper speakers mykyta/lada/tetiana/dmytro/oleksa).
PROTOAGI_TTS_VOICE=lada
PROTOAGI_TTS_MAX_CHARS=600
PROTOAGI_TTS_RESPONSE_FORMAT=opus
PROTOAGI_TTS_SPEED=1.0

# Optional HMAC secret for signed memory-export / memory-import bundles.
PROTOAGI_FEDERATION_SECRET=

# Telegram persona
# Options: mykola, solomiya, or any custom file in config/personas/*.json
PROTOAGI_TELEGRAM_PERSONA=mykola

# Telegram behavior
NIKOLA_REPLY_MODE=smart
NIKOLA_FICTIONAL_SELF=1
# 1 keeps today's single-owner global Telegram memory. Set to 0 to store and
# recall Telegram user facts with per-user isolation.
PROTOAGI_TELEGRAM_GLOBAL_MEMORY=1
# Sticker policy. The default is "low" (~12% bucket pass for auto reactions
# plus a hard cooldown). Set to "off" to disable, "normal/high/always" to
# allow more. Stickers in proactive (initiative) messages are off by
# default; flip NIKOLA_STICKER_INITIATIVE=1 if the chat tone is consistently
# playful. NIKOLA_STICKER_MAX_REPLY_CHARS suppresses stickers when the
# accompanying text is paragraph-shaped (180 chars by default).
NIKOLA_STICKER_FREQUENCY=low
NIKOLA_STICKER_COOLDOWN_MESSAGES=6
NIKOLA_STICKER_MAX_REPLY_CHARS=180
NIKOLA_STICKER_INITIATIVE=0
TELEGRAM_MAX_REPLY_MESSAGES=3
NIKOLA_PROACTIVE=1
NIKOLA_PROACTIVE_CHECK_SECONDS=300
NIKOLA_PROACTIVE_COOLDOWN_SECONDS=21600

# Group-chat reactivity gate.
# When the chat is a group/supergroup and none of the triggers fire,
# the bot stays silent without spending an LLM call on a decision.
# Triggers: reply to the bot, @bot_username, persona alias, "/" command,
# or one of NIKOLA_GROUP_TRIGGER_KEYWORDS (comma-separated, case-insensitive,
# whole-word, Cyrillic-safe). Aliases of the active persona already count as
# triggers, so add only extra hooks like nicknames or shared topic words.
# Example for the solomiya persona that also reacts to "соломі" / "хей":
#   NIKOLA_GROUP_TRIGGER_KEYWORDS=соломі,хей
NIKOLA_GROUP_REPLY_COOLDOWN_SECONDS=120
NIKOLA_GROUP_PASSIVE_REPLY_RATIO=0.04
NIKOLA_GROUP_TRIGGER_KEYWORDS=

# Optional web search tool (Phase 13 plan). Leave PROTOAGI_WEB_SEARCH_URL
# empty to keep the tool disabled. The endpoint must accept GET with
# ?q=<query>&format=json (SearxNG-style). Reuses the SSRF guard from web_get.
PROTOAGI_WEB_SEARCH_URL=
PROTOAGI_WEB_SEARCH_TIMEOUT_SECONDS=10
PROTOAGI_WEB_SEARCH_MAX_RESULTS=5
PROTOAGI_WEB_SEARCH_CACHE_SECONDS=900

# Optional debug capture of the deepseek reasoning channel into the admin
# dashboard. Disabled by default (content can be sensitive).
PROTOAGI_CAPTURE_REASONING=0
PROTOAGI_REASONING_MAX_ENTRIES=20
PROTOAGI_REASONING_MAX_CHARS=3000
