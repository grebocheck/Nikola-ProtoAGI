# ProtoAGI local endpoint
PROTOAGI_BASE_URL=http://127.0.0.1:8080/v1
PROTOAGI_MODEL=gpt-oss-20b-MXFP4
PROTOAGI_DB=data/protoagi.sqlite3
PROTOAGI_TEMPERATURE=0.6
PROTOAGI_TOP_P=1.0
PROTOAGI_MAX_TOKENS=1536

# Telegram Bot API
# Create a token with @BotFather. Keep the real token only in .env.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_POLL_TIMEOUT=25

# Nikola behavior
NIKOLA_REPLY_MODE=smart
NIKOLA_PROACTIVE=1
NIKOLA_PROACTIVE_CHECK_SECONDS=300
NIKOLA_PROACTIVE_COOLDOWN_SECONDS=21600
